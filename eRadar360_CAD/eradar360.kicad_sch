(kicad_sch (version 20230121) (generator eradar360_design_tool)
  (uuid "eradar360-main-schematic")
  (paper "A2")
  (title_block
    (title "eRadar360 / Aegis One — Main Schematic")
    (date "2026-04-15")
    (rev "A")
    (company "embeddedOS.org")
    (comment 1 "Next-Generation Driver Awareness System")
    (comment 2 "120mm x 85mm, 10-layer hybrid PCB")
    (comment 3 "ERAD360-SCH-001 Rev A")
  )


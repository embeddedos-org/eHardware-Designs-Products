  ;; ═══════════════════════════════════════════════════════════
  ;; NET CONNECTIONS (wires)
  ;; ═══════════════════════════════════════════════════════════

  ;; Power: USB-C → PMIC → Rails
  (wire (pts (xy 20 60) (xy 80 60)) (net "VCC_5V"))
  (wire (pts (xy 80 62) (xy 200 62)) (net "VCC_0V85"))
  (wire (pts (xy 80 64) (xy 200 64)) (net "VCC_1V8"))
  (wire (pts (xy 80 66) (xy 60 150)) (net "VCC_1V1"))
  (wire (pts (xy 80 68) (xy 340 60)) (net "VCC_3V3"))

  ;; SPI0: RK3588S ↔ AWR2944 Front
  (wire (pts (xy 200 80) (xy 60 155)) (net "SPI0_CLK"))
  (wire (pts (xy 200 82) (xy 60 157)) (net "SPI0_MOSI"))
  (wire (pts (xy 200 84) (xy 60 159)) (net "SPI0_MISO"))
  (wire (pts (xy 200 86) (xy 60 161)) (net "SPI0_CS0"))

  ;; SPI1: RK3588S ↔ AWR2944 Rear
  (wire (pts (xy 200 90) (xy 60 205)) (net "SPI1_CLK"))
  (wire (pts (xy 200 92) (xy 60 207)) (net "SPI1_MOSI"))
  (wire (pts (xy 200 94) (xy 60 209)) (net "SPI1_MISO"))
  (wire (pts (xy 200 96) (xy 60 211)) (net "SPI1_CS0"))

  ;; I2C0: RK3588S ↔ GPS + Co-processor
  (wire (pts (xy 200 100) (xy 340 122)) (net "I2C0_SDA"))
  (wire (pts (xy 200 102) (xy 340 124)) (net "I2C0_SCL"))
  (wire (pts (xy 200 100) (xy 200 202)) (net "I2C0_SDA"))
  (wire (pts (xy 200 102) (xy 200 204)) (net "I2C0_SCL"))

  ;; UART3: RK3588S ↔ TEKTON3 V2X
  (wire (pts (xy 200 110) (xy 60 252)) (net "UART3_TX"))
  (wire (pts (xy 200 112) (xy 60 254)) (net "UART3_RX"))

  ;; UART4: STM32 ↔ ELM327 OBD-II
  (wire (pts (xy 200 210) (xy 340 202)) (net "UART4_TX"))
  (wire (pts (xy 200 212) (xy 340 204)) (net "UART4_RX"))

  ;; MIPI-DSI: RK3588S → AMOLED
  (wire (pts (xy 200 120) (xy 340 62)) (net "MIPI_DSI_D0_P"))
  (wire (pts (xy 200 122) (xy 340 64)) (net "MIPI_DSI_CLK_P"))

  ;; DDR4: RK3588S ↔ SDRAM
  (wire (pts (xy 200 130) (xy 340 152)) (net "DDR4_BUS"))

  ;; CAN: MCP2551 ↔ OBD-II connector
  (wire (pts (xy 340 242) (xy 20 142)) (net "CANH"))
  (wire (pts (xy 340 244) (xy 20 144)) (net "CANL"))

  ;; Laser ADC: APD → TIA → STM32 ADC
  (wire (pts (xy 60 302) (xy 200 215)) (net "LASER_TIA_1"))
  (wire (pts (xy 60 304) (xy 200 217)) (net "LASER_TIA_2"))
  (wire (pts (xy 60 306) (xy 200 219)) (net "LASER_TIA_3"))
  (wire (pts (xy 60 308) (xy 200 221)) (net "LASER_TIA_4"))
  (wire (pts (xy 60 310) (xy 200 223)) (net "LASER_TIA_5"))

